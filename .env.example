# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Domínio raiz do SaaS (subdomínios serão: tenant.upixel.app)
VITE_ROOT_DOMAIN=upixel.app

# Chave de acesso ao cadastro público (SignupPage)
VITE_SIGNUP_PASSWORD=your-signup-password

# Builder (opcional)
VITE_PUBLIC_BUILDER_KEY=optional-builder-key

# ─── Edge Functions (Supabase Secrets) ───────────────────────
# Configurar via: supabase secrets set GROQ_API_KEY=...

# Groq API — usado por: ai-chat, rag-embed, rag-search
GROQ_API_KEY=your-groq-api-key
